{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "cv-tailor analysis",
  "type": "object",
  "required": [
    "company",
    "role",
    "base_resume_path",
    "summary_edits",
    "bullet_edits",
    "keyword_targets",
    "cover_letter_paragraphs",
    "claims_guardrail"
  ],
  "properties": {
    "company": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "base_resume_path": { "type": "string", "minLength": 1 },
    "summary_edits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["old", "new"],
        "properties": {
          "old": { "type": "string", "minLength": 1 },
          "new": { "type": "string", "minLength": 1 }
        }
      }
    },
    "bullet_edits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["old", "new"],
        "properties": {
          "old": { "type": "string", "minLength": 1 },
          "new": { "type": "string", "minLength": 1 }
        }
      }
    },
    "keyword_targets": { "type": "array", "items": { "type": "string" } },
    "cover_letter_paragraphs": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 10 } },
    "claims_guardrail": { "type": "array", "minItems": 1, "items": { "type": "string" }, "description": "Explicit truthfulness constraints" }
  }
}
