# Career Manager Configuration
# Copy this file to config.yaml and fill in your values.

paths:
  # Base directory for CV/resume files
  cv_base: /path/to/your/CV/directory

integrations:
  # Set to false to skip Todoist sync (pipeline continues without it)
  todoist_enabled: false
  # Set to false to skip email sends
  gmail_enabled: false
  # Set to false to skip JobSpy scraping (uses cached data instead)
  jobspy_enabled: true
  # Set to true to use Tavily for direct role posting links (free tier: 1000 credits/month)
  # Sign up at https://tavily.com to get an API key
  tavily_enabled: false

email:
  from: your-email@gmail.com
  to: your-email@gmail.com
  bcc: ""  # Optional BCC recipient (leave empty to disable)

credentials:
  # Todoist token file path (relative to project root)
  todoist_token: .credentials/todoist-token.json
  # Gmail OAuth token path (relative to project root)
  gmail_token: .credentials/gmail-token.pickle
  # Tavily API key file — JSON with {"api_key": "tvly-..."}
  tavily_token: .credentials/tavily-token.json

pipeline:
  # Action list thresholds and lifecycle behavior.
  # These are the knobs that control how precise vs. broad your shortlist is.
  action_list:
    # Score cutoff for "Apply Now" section (requires a specific role_url).
    apply_min_score: 70
    # Score cutoff for "Watch / Outreach" section (no role_url required).
    watch_min_score: 85
    # Max rows in the Watch / Outreach section even if more companies pass the threshold.
    watch_max_rows: 20
  discovery:
    # Net-new companies are kept only if they score at or above this.
    discover_min_score: 70
    # Per-agent search query budget.
    per_agent_query_budget: 15
    # No minimum-companies quota — agents return what they actually find (including empty).
  lifecycle:
    # A company in 'watching' state for this many consecutive runs → 'archived'.
    archive_grace_runs: 2

query_templates:
  # Optional per-user query patterns. Leave empty to use engine defaults.
  # Use {path_label} as a placeholder for each career path.
  extra_patterns: []
